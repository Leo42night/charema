// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  engineType = "client"
  runtime = "bun"
}

datasource db {
  provider = "sqlite"
}

// simpan data target input mahasiswa, matkul yang diambil semester ini
model RecomTarget { 
  id          Int   @id @default(autoincrement())
  // user key key dari proses index user-items CF, value key matkuls disiman di JSON file
  user_key    Int   @unique 
  // JSON [1,2,3], value key matkuls disiman di JSON file
  // !!! skema item_matkul.json perlu diarchive jika ada update
  matkul_ids  Json 
}

// Simapn hasil score terhadap "apakah hasil rekomendasi membantu? 1-5", apakah score membantu
model Score {
  user_key    Int   @id // user_key sekarang menjadi identitas unik utama
  score_cf    Int
  score_chat  Int
  createdAt  DateTime   @default(now())
}

// simpan achivement
model Achievement {
  user_key   Int   @id // user_key sekarang menjadi identitas unik utama
  tags       Json // ["greeting", "rekomendasi", dsb.]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @default(now())
}

model Feedback {
  id          Int   @id @default(autoincrement())
  user_key    Int? // jika tidak ada maka email wajib
  email       String?
  input       String
  res_tag     String // "greeting"
  res_message String
  feedback    String
  createdAt  DateTime   @default(now())
}