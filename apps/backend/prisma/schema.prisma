// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  engineType = "client"
  runtime = "bun"
}

datasource db {
  provider = "sqlite"
}

// simpan data target input mahasiswa, matkul yang diambil semester ini
model RecomTarget { 
  // user key key dari proses index user-items CF, value key matkuls disiman di JSON file
  id          Int   @id @default(autoincrement()) // bisa ada beberapa recom
  user_key    Int   
  // JSON [1,2,3], value key matkuls disiman di JSON file
  // !!! skema item_matkul.json perlu diarchive jika ada update
  matkul_ids  Json
  created_at  DateTime   @default(now()) // save tiap ada data baru
  updated_at  DateTime   @updatedAt // max 3 kali, setelah itu mode upsert data lama
}

// POST progress untuk simpan Score & Achievement 
// Simapn hasil score terhadap "apakah hasil rekomendasi membantu? 1-5", apakah score membantu
model Score {
  user_key    Int   @id // user_key sekarang menjadi identitas unik utama
  score_cf    Int
  score_chat  Int
  message     String? // kritik atau saran
  created_at  DateTime   @default(now()) // jadi catatan update untuk Achievement
}

model Achievement {
  user_key   Int   @id // user_key sekarang menjadi identitas unik utama
  tags       Json // ["greeting", "rekomendasi", dsb.]
  created_at  DateTime   @default(now()) // interaksi pertama (walaupun tidak langsung simpan)
}

// Feedback di limit 4 saja, jika ada feedback baru, lakukan upsert data lama
model Feedback {
  id          Int   @id @default(autoincrement())
  user_key    Int? // jika tidak ada maka email wajib
  email       String?
  input       String
  res_tag     String // "greeting"
  res_message String
  feedback    String
  created_at  DateTime   @updatedAt // jika update, maka berubah
}