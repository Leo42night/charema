{
  "name": "backend",
  "module": "src/index.ts",
  "private": true,
  "scripts": {
    "dev": "bun run --env-file=.env --env-file=.env.local --watch src/server.ts",
    "devh": "bun run --env-file=.env --env-file=.env.local --watch src/server.ts",
    "devpg": "bun run --env-file=.env --env-file=.env.prod.local --watch --no-deprecation src/server-pg.ts",
    "dump": "bun prisma/dump-to-json.ts",
    "client:pg": "bunx prisma generate --schema prisma/schema-pg.prisma",
    "seed:pg": "bun --env-file=.env.production prisma/seed.ts",
    "migrate:pg": "bun --env-file=.env.production prisma/migrate-pg.ts",
    "seed:pg-json": "bun --env-file=.env.production prisma/seed-from-json.ts",
    "encrypt": "bun dev/encrypt-json.ts"
  },
  "dependencies": {
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.9.3",
    "crypto-js": "^4.2.0",
    "elysia": "^1.4.28",
    "shared": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "prisma": "^7.8.0",
    "tsdown": "^0.21.10"
  },
  "type": "module",
  "peerDependencies": {
    "typescript": "^5"
  }
}