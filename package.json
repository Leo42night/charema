{
  "name": "monorepo",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev-be": "bun run --filter 'backend' dev",
    "dev:turso": "bun run --filter '*' dev:turso",
    "build": "bun run --filter '*' build",
    "preview": "bun run --filter '*' preview"
  }
}